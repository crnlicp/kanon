{
  "name": "culturhub",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm -r --if-present run check",
    "fix": "pnpm -r --if-present run fix",
    "bindgen": "dfx bindgen backend --canister-bindgen ic-js --out-dir ./src/frontend/src/declarations"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  }
}
