{
  "canisters": {
    "backend": {
      "main": "src/backend/main.mo",
      "type": "motoko",
      "package": "backend"
    },
    "frontend": {
      "type": "assets",
      "source": ["src/frontend/dist"],
      "dependencies": ["backend"]
    }
  },
  "defaults": {
    "build": {
      "args": "--package caffeineai-object-storage .mops/caffeineai-object-storage@0.1.1/src --package caffeineai-authorization .mops/caffeineai-authorization@0.1.0/src",
      "packagers": {
        "motoko": "mops",
        "typescript": "tsc"
      }
    }
  },
  "networks": {
    "local": {
      "providers": ["http://127.0.0.1:4943"],
      "type": "persistent"
    }
  },
  "version": 1
}
