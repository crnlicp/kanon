{
  "canisters": {
    "backend": {
      "main": "src/backend/main.mo",
      "type": "motoko",
      "candid": "src/backend/backend.did"
    },
    "frontend": {
      "type": "assets",
      "source": ["src/frontend/dist"],
      "dependencies": ["backend"],
      "storage": ["50"],
      "gzip": true
    }
  },
  "defaults": {
    "build": {
      "packagers": {
        "motoko": "mops",
        "typescript": "tsc"
      }
    }
  },
  "networks": {
    "mainnet": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    }
  },
  "version": 1
}
